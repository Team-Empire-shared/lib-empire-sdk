{
  "name": "@team-empire-shared/sdk",
  "version": "3.2.2",
  "description": "Typed BOS API client for Empire Overseas Education frontends",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "keywords": [
    "empire",
    "bos",
    "sdk",
    "api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Team-Empire-shared/lib-empire-sdk.git"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
