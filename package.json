{
  "name": "@empireo-org/sdk",
  "version": "1.0.2",
  "description": "Official TypeScript SDK for the EmpireOE API — auto-generated types from OpenAPI",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No unit tests — type safety enforced by build' && exit 0",
    "generate": "bash scripts/generate-types.sh"
  },
  "files": ["dist", "src"],
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/empireO-Org/empireoe-sdk.git"
  },
  "devDependencies": {
    "openapi-typescript": "^7.6.0",
    "typescript": "^5.7.0"
  }
}
