    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/empireoe-ai/empireoe-sdk.git"
  },
  "devDependencies": {
    "openapi-typescript": "^7.6.0",
    "typescript": "^5.7.0"
  }
}
